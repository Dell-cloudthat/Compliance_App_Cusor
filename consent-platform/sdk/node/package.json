{
  "name": "@consent-platform/node",
  "version": "1.0.0",
  "description": "Node.js SDK for Consent as a Service Platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
